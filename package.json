{
  "name": "mcp-inspector",
  "version": "0.1.0",
  "description": "CLI que inspeciona servidores MCP ao vivo e gera um relatório técnico de 15 etapas (qualidade, compatibilidade, performance, segurança e score).",
  "type": "module",
  "bin": {
    "mcp-inspector": "dist/index.js"
  },
  "main": "dist/index.js",
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "lint": "tsc --noEmit"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "inspector",
    "audit",
    "cli"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "commander": "^12.1.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^4.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^4.0.0"
  },
  "pnpm": {
    "overrides": {
      "vite": "^7.3.0"
    }
  }
}
